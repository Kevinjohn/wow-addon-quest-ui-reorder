package-as: QuestUIReorder

enable-nolib-creation: no

# Ship our curated changelog instead of the packager's auto-generated git-log
# dump. (With no manual-changelog, the packager builds a CHANGELOG.md from git
# history and adds it to the zip regardless of the ignore list below.)
manual-changelog:
  filename: CHANGELOG.md
  markup-type: markdown

# Repo-only files that should never ship inside the addon zip.
ignore:
  - .release
  - .github
  - .gitignore
  - .gitattributes
  - .luacheckrc
  - .pkgmeta
  - scripts
  - tests
  - docs
  - README.md
  - README-DEV.md
  - CONTRIBUTING.md
  - SECURITY.md
  - CODE_OF_CONDUCT.md
  - _wow-Addon-Publishing-Readiness.md
